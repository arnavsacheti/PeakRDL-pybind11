# ---------------------------------------------------------------------------
# Per-SoC array metadata (Phases 1+2 of Tier 3 RDL array support; issue #138).
#
# ``_ARRAY_PATHS`` lists every arrayed node's RDL path (with the
# leading SoC-root segment stripped, mirroring ``Signal`` paths in
# ``runtime/signals.py``). ``_wrap_arrays`` walks the path on a freshly
# created SoC, collects the entry references via the C++ binding's
# sequence protocol, builds an :class:`ArrayView` from them, and stashes
# the wrapper in a per-instance cache.
#
# A class-level property (installed once at module import) routes
# ``parent.<array>`` lookups through the cache, falling back to the
# original pybind11 ``def_readonly`` getter when the wrapper has not
# been installed yet. Pybind11's ``def_readonly`` creates a *data*
# descriptor that wins over instance ``__dict__``; replacing it with
# our own data descriptor is the way to let user-facing attribute
# access return the ``ArrayView`` instead of the raw C++ array.
#
# Phase 2 (#138) extends the path list to cover regfile arrays
# alongside the Phase 1 register arrays. Addrmap arrays + multi-dim +
# field arrays still raise ``NotSupportedError`` from the exporter.
# ---------------------------------------------------------------------------
from peakrdl_pybind11.runtime import arrays as _peakrdl_arrays

# Phase 5 (#138) extends the per-array tuple with strides and the
# entry-type name so :class:`ArrayInfo` can expose them.  Order:
# ``(rdl_path_with_root, shape_tuple, strides_tuple, entry_type_name)``.
# Phases 1-4 used a 2-tuple; the new wrapping code unpacks defensively
# so a stale generated runtime that still emits the 2-tuple keeps
# working (with empty strides / entry_type_name).
_ARRAY_PATHS: list[tuple[str, tuple[int, ...], tuple[int, ...], str]] = [
{% for array in nodes.arrays %}
    ("{{ array.node.get_path() }}", ({% for d in array.dimensions %}{{ d }}, {% endfor %}), ({% for s in array.strides %}{{ s }}, {% endfor %}), "{{ array.node | pybind_name }}_t"),
{% endfor %}
]

