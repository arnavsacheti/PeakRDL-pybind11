def create():
    """Create a new instance of the {{ soc_name }} register map."""
    soc = {{ soc_name }}_t()
    # Wrap RDL array members in :class:`ArrayView` before any post-create
    # hook fires. Sibling hooks (observers, snapshot tooling, etc.) that
    # walk ``soc`` then see the typed ``ArrayView`` surface for arrayed
    # children rather than the raw C++ ``ArrayBase`` binding.
    {% if nodes.reg_arrays %}
    _wrap_arrays(soc)
    {% endif %}
    # Sibling units can attach observers, snapshot tooling, etc.
    _peakrdl_registry.fire_post_create_hooks(soc)
    return soc


