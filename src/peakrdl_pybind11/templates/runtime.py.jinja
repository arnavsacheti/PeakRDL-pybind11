# Per-instance ArrayView cache: ``id(parent) -> {attr_name: ArrayView}``.
# Keyed by ``id`` so the property doesn't have to hash arbitrary
# pybind11 objects (and so we don't accidentally extend their
# lifetime). Entries are cleared by :func:`_wrap_arrays` on every
# ``create()``, which is the only place we'd see a stale id (the prior
# SoC at that address has already been garbage-collected by the time
# the new one shares its id).
_ARRAY_VIEW_CACHE: dict[int, dict[str, object]] = {}

# ``(parent_cls, attr_name) -> original pybind11 descriptor``. Captured
# by :func:`_install_array_properties` before we overwrite the class
# attribute, so :func:`_wrap_arrays` can still reach the C++ array
# through the original ``def_readonly`` getter.
_NATIVE_ARRAY_DESCRIPTORS: dict[tuple[type, str], object] = {}


def _strip_soc_root(path: str) -> str:
    """Drop the leading SoC-root segment from an RDL path.

    Mirrors ``signals._strip_root``. ``"{{ soc_name }}.lut"`` →
    ``"lut"``; ``"{{ soc_name }}.peripherals.dma.chan"`` →
    ``"peripherals.dma.chan"``. Trailing empty-array suffixes are
    stripped so the path is a plain dotted Python attribute walk —
    for a multi-dim array (Phase 3, #138) the suffix is repeated
    (e.g. ``foo[][]``) so we loop instead of stripping just one pair.
    """
    while path.endswith("[]"):
        path = path[:-2]
    if "." not in path:
        return path
    _, _, rest = path.partition(".")
    return rest


def _array_property(attr: str, native_getter):
    """Build a data descriptor for an arrayed child attribute.

    ``attr`` is the Python attribute name (e.g. ``"lut"``). The
    returned property's getter consults :data:`_ARRAY_VIEW_CACHE`
    first and falls back to ``native_getter`` (the original pybind11
    ``def_readonly`` accessor) when no wrapper has been installed —
    handy if a user looks up the attribute before ``create()`` has
    fired the post-create hook chain.

    The ``_peakrdl_array_wrapper`` marker on ``_fget`` lets
    :func:`_install_array_properties` detect a previously-installed
    wrapper and skip re-wrapping (idempotency under hot reload /
    duplicate module import).
    """
    def _fget(self):
        cache = _ARRAY_VIEW_CACHE.get(id(self))
        if cache is not None and attr in cache:
            return cache[attr]
        return native_getter(self)

    _fget._peakrdl_array_wrapper = True

    def _fset(self, value):
        cache = _ARRAY_VIEW_CACHE.setdefault(id(self), {})
        cache[attr] = value

    return property(_fget, _fset)


def _install_array_properties() -> None:
    """Swap pybind11 ``def_readonly`` accessors for cache-routing properties.

    Runs once at module import. Captures the original pybind11
    descriptor in :data:`_NATIVE_ARRAY_DESCRIPTORS` (keyed by parent
    class + attribute name) before replacing the class attribute with
    a Python data descriptor that consults :data:`_ARRAY_VIEW_CACHE`.

    Idempotent: ``_array_property`` stamps the getter with
    ``_peakrdl_array_wrapper = True``; a second invocation (hot
    reload, dual ``__init__.py`` import paths) skips already-wrapped
    attributes rather than chaining a new layer.

    Phases 1+2 cover arrays whose parent is the SoC class (register or
    regfile arrays at the SoC root). A future phase will handle nested
    parents — e.g. ``soc.peripherals.dma.channel[]`` where
    ``peripherals`` and ``dma`` are themselves nested regfiles. Those
    paths raise :class:`NotImplementedError` here so users see a
    pointed message rather than silent breakage.
    """
    soc_cls = {{ soc_name }}_t
    for entry in _ARRAY_PATHS:
        # Phases 1-4 stored 2-tuples; Phase 5 (#138) stores 4-tuples
        # ``(path, shape, strides, entry_type_name)``. Unpack defensively
        # so a freshly-regenerated runtime works against an older
        # ``arrays.py`` and vice versa during transitions.
        path_with_root = entry[0]
        rel_path = _strip_soc_root(path_with_root)
        parent_path, _, attr = rel_path.rpartition(".")
        if parent_path:
            # Future phase: arrays nested inside a regfile/addrmap.
            # The generated runtime intentionally raises rather than
            # silently doing the wrong thing.
            raise NotImplementedError(
                f"Array wrapping for nested-parent path {path_with_root!r} "
                "is not yet supported. Phase 2 lands SoC-root register and "
                "regfile arrays; arrays one level deep inside a regfile "
                "are tracked at "
                "https://github.com/arnavsacheti/PeakRDL-pybind11/issues/138."
            )
        parent_cls = soc_cls

        native_descriptor = vars(parent_cls).get(attr)
        if native_descriptor is None:
            continue
        existing_fget = getattr(native_descriptor, "fget", None)
        if getattr(existing_fget, "_peakrdl_array_wrapper", False):
            # Already installed — preserve the originally-captured
            # pybind11 descriptor and move on. Idempotent under
            # duplicate import (the exporter writes the runtime to both
            # ``out/__init__.py`` and ``out/<soc>/__init__.py``).
            continue
        _NATIVE_ARRAY_DESCRIPTORS[(parent_cls, attr)] = native_descriptor

        # Bind the descriptor into the closure so the swap is
        # idempotent (rerunning ``_install_array_properties`` keeps
        # using the same fallback rather than chaining a new layer).
        def _native_getter(self, _desc=native_descriptor):
            return _desc.__get__(self, type(self))

        setattr(parent_cls, attr, _array_property(attr, _native_getter))


_install_array_properties()


def _flatten_cxx_array(cxx_array, dims: tuple[int, ...]) -> list:
    """Walk a nested C++ ``ArrayBase`` chain into a flat row-major list.

    For a 1-D array (``len(dims) == 1``) this is just
    ``[cxx_array[i] for i in range(dims[0])]`` — identical to what
    Phase 1 + Phase 2 did inline. For ``len(dims) > 1`` (Phase 3 of
    Tier 3 array support, #138) it recurses into each outer entry
    and concatenates the results, producing the flat row-major list
    that :class:`ArrayView` expects (its ``_indices`` and tuple
    ``__getitem__`` both assume row-major).

    The leaf elements are the same pybind11 ``reference_internal``
    handles that direct indexing returns, so identity stability
    survives flattening — ``soc.matrix[2, 5] is soc.matrix[2][5]``
    holds because both hit the same underlying entry object.
    """
    if not dims:
        return []
    if len(dims) == 1:
        return [cxx_array[i] for i in range(dims[0])]
    inner_dims = dims[1:]
    flat: list = []
    for i in range(dims[0]):
        flat.extend(_flatten_cxx_array(cxx_array[i], inner_dims))
    return flat


def _wrap_arrays(soc) -> None:
    """Build an :class:`ArrayView` for each arrayed child of ``soc``.

    The view is stashed in :data:`_ARRAY_VIEW_CACHE` so the
    class-level data descriptor returns it on attribute access. The
    raw C++ binding remains reachable through the original pybind11
    descriptor — only the user-facing attribute switches.

    Phases 1+2: arrays at the SoC root only; nested-parent paths are
    skipped here because ``_install_array_properties`` already raised
    on them at module-import time. Phase 3 (#138) adds multi-dim
    arrays — the flattened element list keeps ``ArrayView``'s
    row-major indexing happy.
    """
    cache: dict[str, object] = {}
    for entry in _ARRAY_PATHS:
        # Phase 5 (#138) extends ``_ARRAY_PATHS`` from a 2-tuple to a
        # 4-tuple ``(path, shape, strides, entry_type_name)``. Unpack
        # defensively so the runtime works against both shapes.
        path_with_root = entry[0]
        shape = entry[1]
        strides = entry[2] if len(entry) > 2 else ()
        entry_type_name = entry[3] if len(entry) > 3 else ""

        rel_path = _strip_soc_root(path_with_root)
        parent_path, _, attr = rel_path.rpartition(".")
        parent = soc
        if parent_path:
            for segment in parent_path.split("."):
                parent = getattr(parent, segment)
        # Reach through the captured pybind11 descriptor to get the
        # raw C++ array — bypassing our cache-routing property, which
        # would otherwise loop back into the (still-empty) cache.
        native_desc = _NATIVE_ARRAY_DESCRIPTORS.get((type(parent), attr))
        if native_desc is None:
            continue
        cxx_array = native_desc.__get__(parent, type(parent))
        # Pybind11 ``reference_internal`` ties each entry's lifetime to
        # the C++ array node (owned by the parent), so the Python refs
        # stay valid for the SoC's life. For multi-dim arrays the
        # helper walks the nested ``ArrayBase`` chain and flattens to
        # row-major; the ``ArrayView`` ``shape`` is then the full
        # multi-dim tuple from ``_ARRAY_PATHS``.
        elements = _flatten_cxx_array(cxx_array, shape)
        # SoC-rooted dotted path for :class:`ArrayInfo`. ``rel_path``
        # is the array's path under the SoC (e.g. ``"lut"`` or
        # ``"peripherals.dma.channel"``); join it with the soc instance
        # name for a usable ``info.path``. We fall back to the bare
        # relative path when the user hasn't named the SoC node.
        soc_name_prefix = getattr(type(soc), "__name__", "soc")
        if soc_name_prefix.endswith("_t"):
            soc_name_prefix = soc_name_prefix[:-2]
        view_path = f"{soc_name_prefix}.{rel_path}" if soc_name_prefix else rel_path
        view = _peakrdl_arrays.wrap_array(
            type(parent),
            attr,
            elements,
            shape,
            path=view_path,
            strides=strides,
            entry_type_name=entry_type_name,
        )
        cache[attr] = view
    if cache:
        _ARRAY_VIEW_CACHE[id(soc)] = cache
{% endif %}


