        _reg_cls,
        {
            "fields": _spec,
            "writable": _REGISTER_FIELD_WRITABLE.get(_reg_cls, {}),
            "flag_type": _FLAG_REG_TYPES.get(_reg_cls),
            "enum_type": _ENUM_REG_TYPES.get(_reg_cls),
