{% for addrmap in nodes.addrmaps %}
{% if addrmap != top_node %}
// Forward declaration for {{ addrmap.get_path() }}
class {{ addrmap | pybind_name }}_t;
{% endif %}
{% endfor %}

{% for regfile in nodes.regfiles %}
// Forward declaration for {{ regfile.get_path() }}
class {{ regfile | pybind_name }}_t;
{% endfor %}

{% for mem in nodes.mems %}
// Forward declaration for memory {{ mem.get_path() }}
class {{ mem | pybind_name }}_t;
{% endfor %}

{# Forward declarations for array classes. Both register and regfile
   arrays are referenced by parent classes (e.g. SoC class member
   instantiation), but the *definitions* land in different partials:
   register arrays in ``arrays.hpp.jinja`` (after registers), regfile
   arrays in ``regfile_arrays.hpp.jinja`` (after regfiles). Forward-
   declaring both up front keeps any parent ``<entry>_array_t`` member
   reference well-formed regardless of include order.

   Phase 3 (#138): multi-dim arrays add ``<entry>_inner_<level>_array_t``
   intermediate types. Forward-declare all levels including the
   intermediates so any cross-partial reference (e.g. the pybind11
   binding partial) compiles even when the partial it sits in lands
   before the array definition partial.
#}
{% for array in nodes.arrays %}
// Forward declaration for {{ array.kind }} array {{ array.node.get_path() }}
class {{ array.node | pybind_name }}_array_t;
{% if array.dimensions | length > 1 %}
{# Inner-level intermediates for multi-dim. #}
{% for level in range(array.dimensions | length - 1) %}
class {{ array.node | pybind_name }}_inner_{{ level }}_array_t;
{% endfor %}
{% endif %}
{% endfor %}
