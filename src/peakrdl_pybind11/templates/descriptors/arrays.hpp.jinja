{# Per-array C++ class for register arrays. Each arrayed entry type
   gets a small subclass of ``ArrayBase<entry_t>`` that pre-fills
   (name, num_entries, stride), keeping the parent regfile/addrmap
   construction uniform with the non-arrayed case: parents always pass
   a single ``base_offset`` to their child members.

   This partial covers ``kind == "reg"`` entries from ``nodes.arrays``.
   ``kind == "regfile"`` entries live in ``regfile_arrays.hpp.jinja``
   (included **after** ``regfiles.hpp.jinja`` so the entry type is
   complete before ``std::vector<<rf>_t>`` instantiates).

   Phases 1+2 (issue #138) handle 1-D register + regfile arrays; multi-
   dim and addrmap arrays still raise ``NotSupportedError`` in the
   exporter.
#}
{% for array in nodes.arrays if array.kind == "reg" %}
// Register array: {{ array.node.get_path() }}
class {{ array.node | pybind_name }}_array_t : public ArrayBase<{{ array.node | pybind_name }}_t> {
public:
    {{ array.node | pybind_name }}_array_t(uint64_t base_offset)
        : ArrayBase<{{ array.node | pybind_name }}_t>(
              "{{ array.node.inst_name | safe_id }}", base_offset,
              0x{{ "%x" | format(array.relative_offset) }},
              {{ array.dimensions[0] }}, {{ array.stride }}) {}
};

{% endfor %}
