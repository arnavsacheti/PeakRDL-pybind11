{# Per-array C++ class for register arrays. Each arrayed entry type
   gets a small subclass of ``ArrayBase<entry_t>`` that pre-fills
   (name, num_entries, stride), keeping the parent regfile/addrmap
   construction uniform with the non-arrayed case: parents always pass
   a single ``base_offset`` to their child members.

   This partial covers ``kind == "reg"`` entries from ``nodes.arrays``.
   ``kind == "regfile"`` entries live in ``regfile_arrays.hpp.jinja``
   (included **after** ``regfiles.hpp.jinja`` so the entry type is
   complete before ``std::vector<<rf>_t>`` instantiates).

   Phase 3 (issue #138) adds multi-dim register arrays: when
   ``array.dimensions`` has length > 1 we emit one nested
   ``ArrayBase`` subclass per axis. The innermost level wraps the
   entry type directly (``ArrayBase<<entry>_t>``); each outer level
   wraps the next-inner level's array type. Only the outermost
   subclass is named ``<entry>_array_t`` (so parent classes can keep
   their uniform ``<entry>_array_t name{offset_};`` instantiation);
   intermediate levels are named ``<entry>_inner_<level>_array_t``
   where ``level`` counts from ``0`` (innermost) outward, skipping the
   outermost.

   Phase 1 + Phase 3 stayed in one file because the multi-dim case
   degenerates cleanly to the 1-D case when ``len(dimensions) == 1``.
   The same loop emits a single typedef for 1-D and N typedefs for
   N-D arrays.
#}
{% for array in nodes.arrays if array.kind == "reg" %}
{% set _entry_name = array.node | pybind_name %}
{% set _entry_t = _entry_name ~ "_t" %}
{% set _dims = array.dimensions %}
{% set _strides = array.strides %}
{% if _dims | length == 1 %}
// Register array (1-D): {{ array.node.get_path() }}
class {{ _entry_name }}_array_t : public ArrayBase<{{ _entry_t }}> {
public:
    {{ _entry_name }}_array_t(uint64_t base_offset)
        : ArrayBase<{{ _entry_t }}>(
              "{{ array.node.inst_name | safe_id }}", base_offset,
              0x{{ "%x" | format(array.relative_offset) }},
              {{ _dims[0] }}, {{ _strides[0] }}) {}
};

{% else %}
// Register array (multi-dim, {{ _dims | length }}-D): {{ array.node.get_path() }}
// One ``ArrayBase`` subclass per axis; the outermost is named
// ``<entry>_array_t`` (so parent classes can stay uniform), the
// intermediates are ``<entry>_inner_<level>_array_t``. Level 0 is
// innermost. The innermost wraps the entry type directly; each outer
// level wraps the next-inner array type.
{# Innermost level: wraps the entry type. Single-arg ctor pre-fills
   (name="", base, rel=0, count=dims[-1], stride=strides[-1]). The
   per-level ``relative_offset`` is zero — only the outermost level
   carries the array's RDL ``raw_address_offset``; inner levels add
   nothing on top. The intermediate's ``name`` is empty too because
   it's never the user-facing identifier (the outermost provides
   that). #}
class {{ _entry_name }}_inner_0_array_t : public ArrayBase<{{ _entry_t }}> {
public:
    {{ _entry_name }}_inner_0_array_t(uint64_t base_offset)
        : ArrayBase<{{ _entry_t }}>(
              "", base_offset, 0x0,
              {{ _dims[-1] }}, {{ _strides[-1] }}) {}
};

{# Intermediate levels: iterate from level 1 (one out from innermost)
   to level N-2 (one in from outermost). ``levels_inner_to_outer``
   carries the axis indices in row-major order; we walk it in reverse
   so each level can reference the next-inner level's typedef name.
   For a 3-D array ``[A][B][C]``: levels = [0, 1, 2] where 0 is C
   (innermost) and 2 is A (outermost). We emit:
   * level 0 = innermost ``C`` typedef (above)
   * level 1 = intermediate ``B`` typedef
   * level 2 = outermost ``A`` typedef (below)
#}
{% for level in range(1, _dims | length - 1) %}
{# axis_idx = the index into ``_dims`` corresponding to this level.
   Level 0 is innermost = last axis = _dims[-1] = _dims[N-1].
   Level k is _dims[N-1-k]. #}
{% set axis_idx = _dims | length - 1 - level %}
class {{ _entry_name }}_inner_{{ level }}_array_t : public ArrayBase<{{ _entry_name }}_inner_{{ level - 1 }}_array_t> {
public:
    {{ _entry_name }}_inner_{{ level }}_array_t(uint64_t base_offset)
        : ArrayBase<{{ _entry_name }}_inner_{{ level - 1 }}_array_t>(
              "", base_offset, 0x0,
              {{ _dims[axis_idx] }}, {{ _strides[axis_idx] }}) {}
};

{% endfor %}
{# Outermost level: wraps the next-inner array type. Carries the
   RDL inst_name and the array's relative offset; nests
   ``len(_dims) - 1`` levels deep. #}
class {{ _entry_name }}_array_t : public ArrayBase<{{ _entry_name }}_inner_{{ _dims | length - 2 }}_array_t> {
public:
    {{ _entry_name }}_array_t(uint64_t base_offset)
        : ArrayBase<{{ _entry_name }}_inner_{{ _dims | length - 2 }}_array_t>(
              "{{ array.node.inst_name | safe_id }}", base_offset,
              0x{{ "%x" | format(array.relative_offset) }},
              {{ _dims[0] }}, {{ _strides[0] }}) {}
};

{% endif %}
{% endfor %}
